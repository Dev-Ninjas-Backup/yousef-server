model User {
  id           String       @id @default(uuid())
  email        String       @unique
  fullName     String?
  password     String?
  bio          String?
  phone        String?      @unique
  // ---------- file---------------------
  tradeLicense String?
  garageLogo   String?
  profilePhoto String?
  // -------- garage information-------
  address      String?
  city         String?
  emirate      String?
  garageName   String?
  garageStatus GarageStatus @default(PENDING)
  // ------------------ Google Authentication ------------------
  googleId     String?      @unique
  emailOtp     Int?
  otpExpiry    DateTime?
  isVerified   Boolean      @default(false)
  ReviewAlerts Boolean      @default(false)

  // ------------------ Password Reset OTP ---------------------
  resetOtp       Int?
  resetOtpExpiry DateTime?

  // ------------------ Account Status -------------------------
  isActive                Boolean           @default(true)
  isDeleted               Boolean           @default(false)
  deletedAt               DateTime?
  isMembership            Boolean           @default(false)
  isEmailNotification     Boolean           @default(false)
  isCustomerInquiryAlerts Boolean           @default(false)
  isSmsNotification       Boolean           @default(false)
  isEmailPromotional      Boolean           @default(false)
  isGarageVerified        Boolean           @default(false)
  // Trial tracking
  trialStartDate          DateTime?
  trialEndDate            DateTime?
  isTrialActive           Boolean           @default(false)
  productApprovalAlerts   Boolean           @default(false)
  freeProductsListing     Int               @default(0)
  // Payment tracking
  hasPaid                 Boolean           @default(false)
  nextBillingDate         DateTime?
  // ------------------ Role & Category ------------------------
  role                    UserRole          @default(CAR_OWNER)
  serviceCategories       ServiceCategory[]

  // ------------------ Membership -----------------------------
  Payment            Payment[]
  subscriptionEndsAt DateTime?

  // ------------------ Relations ------------------------------
  UserNotification   UserNotification[]
  notificationToggle NotificationToggle?
  garages            Garage[] // One user can have many garages

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

enum UserRole {
  CAR_OWNER
  GARAGE_OWNER
  SUPER_ADMIN
  MEMBER
}

enum ServiceCategory {
  MECHANICAL_REPAIR
  AC_HEATING
  ELECTRICAL_SYSTEMS
  BODY_AND_PAINT
  DIAGNOSTICS
  GENERAL_MAINTENANCE
}

enum GarageStatus {
  APPROVE
  PENDING
  DECLINE
}
