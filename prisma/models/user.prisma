model User {
  id           String    @id @default(uuid())
  email        String    @unique
  fullName     String?
  password     String?
  bio          String?
  phone        String?   @unique
  // ---------- file---------------------
  tradeLicense String?
  garageLogo   String?
  profilePhoto String?
  // ------------------ Google Authentication ------------------
  googleId     String?   @unique
  emailOtp     Int?
  otpExpiry    DateTime?
  isVerified   Boolean   @default(false)
  ReviewAlerts Boolean   @default(false)

  // ------------------ Password Reset OTP ---------------------
  resetOtp       Int?
  resetOtpExpiry DateTime?

  // ------------------ Account Status -------------------------
  isActive        Boolean          @default(true)
  isDeleted       Boolean          @default(false)
  deletedAt       DateTime?
  isMembership    Boolean          @default(false)
  // ------------------ Role & Category ------------------------
  role            UserRole
  serviceCategory ServiceCategory?

  // ------------------ Membership -----------------------------
  Payment            Payment[]
  subscriptionEndsAt DateTime?

  // ------------------ Relations ------------------------------
  UserNotification   UserNotification[]
  notificationToggle NotificationToggle?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

enum UserRole {
  CAR_OWNER
  GARAGE_OWNER
  SUPER_ADMIN
  MEMBER
}

enum ServiceCategory {
  MECHANICAL_REPAIR
  AC_HEATING
  ELECTRICAL_SYSTEMS
  BODY_AND_PAINT
  DIAGNOSTICS
  GENERAL_MAINTENANCE
}
