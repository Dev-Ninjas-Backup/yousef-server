model NotificationToggle {
  id                   String  @id @default(uuid())
  email                Boolean @default(false)
  userUpdates          Boolean @default(false)
  message              Boolean @default(false)
  userRegistration     Boolean @default(false)
  CustomerInquiryAlert Boolean @default(false)
  NewMessage           Boolean @default(false)
  ProductApproveUpdate Boolean @default(false)
  Message              Boolean @default(false)

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}
